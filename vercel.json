{
  "version": 2,
  "rewrites": [
    { "source": "/api/crichd", "destination": "/api/crichd.js" },
    { "source": "/api/crichd-proxy", "destination": "/api/crichd-proxy.js" },
    { "source": "/api/watchwrestling", "destination": "/api/watchwrestling.js" },
    { "source": "/api/icc", "destination": "/api/webcric" },
    { "source": "/api/webcric", "destination": "/api/webcric.js" },
